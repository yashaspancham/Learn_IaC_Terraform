# Terraform provider plugins and modules — downloaded by `terraform init`, never commit
.terraform/

# State files — contain real infrastructure state, often include sensitive values
*.tfstate
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Terraform plan files — binary, environment-specific, can contain secrets
*.tfplan
tfplan

# Variable files — often contain secrets (API keys, passwords, etc.)
*.tfvars
*.tfvars.json

# Local override files — machine-specific, not meant for sharing
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config file
.terraformrc
terraform.rc

# Private keys and certificates — never commit
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert

# Environment files — may contain AWS keys, tokens, passwords
.env
.env.*

# AWS credentials if accidentally copied here
credentials
*credentials*

# OS noise
.DS_Store
Thumbs.db
